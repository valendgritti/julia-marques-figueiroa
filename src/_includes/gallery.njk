<section class="detail-hero">
  <a class="back-link" href="{{ '/index.html#trabalhos' | url }}">← Voltar aos trabalhos</a>
  <div class="detail-title-row reveal"><div><p class="eyebrow">{{ eyebrow }}</p><h1>{{ titulo | safe }}</h1></div><p class="detail-summary">{{ resumo }}</p></div>
  {% if capa %}<div class="detail-cover project-image--{{ categoria }} reveal"><img src="{{ capa | url }}" alt="{{ capaAlt }}" /></div>{% endif %}
  <dl class="project-facts reveal">{% for item in fatos %}<div><dt>{{ item.rotulo }}</dt><dd>{{ item.valor }}</dd></div>{% endfor %}</dl>
</section>
<section class="detail-content section reveal"><h2>Sobre o<br /><em>trabalho</em></h2><div class="detail-copy">{{ content | safe }}{% if linkExterno %}<a class="project-action" href="{{ linkExterno }}">{{ linkTexto or 'Ver projeto ↗' }}</a>{% endif %}</div></section>
{% if galeria %}<section class="photo-gallery-section section">
  <header class="photo-gallery-heading reveal"><h2>{% if modelo == "fotografia-digital" %}Série digital{% else %}Ensaios & frames{% endif %}</h2><p>Seleção de imagens do projeto.</p></header>
  {% if modelo == "fotografia-digital" %}<div class="digital-mosaic reveal">{% for imagem in galeria %}<figure class="digital-frame"><img src="{{ imagem.arquivo | url }}" alt="{{ imagem.alt }}" loading="lazy" /></figure>{% endfor %}</div>
  {% else %}<div class="still-mosaic still-mosaic--flexible reveal">{% for imagem in galeria %}<figure class="still-frame"><img src="{{ imagem.arquivo | url }}" alt="{{ imagem.alt }}" loading="lazy" /></figure>{% endfor %}</div>{% endif %}
</section>{% endif %}
{% if creditos %}<section class="detail-credits section reveal"><h2>Ficha técnica</h2><dl class="credits">{% for item in creditos %}<div><dt>{{ item.rotulo }}</dt><dd>{{ item.valor }}</dd></div>{% endfor %}</dl></section>{% endif %}
<a class="next-project" href="{{ '/index.html#trabalhos' | url }}"><span>Navegação</span><strong>Ver todos os projetos →</strong></a>
