{% set pageTitle = titulo + " — Julia Figueirôa" %}
{% set description = descricaoSeo or resumo %}
{% if modelo == "video-vertical" %}{% set bodyClass = "project-page vertical-video-page" %}
{% elif modelo == "roteiro" %}{% set bodyClass = "project-page script-project-page" %}
{% elif modelo == "galeria-still" %}{% set bodyClass = "project-page photo-gallery-page photo-gallery-page--still" %}
{% elif modelo == "fotografia-digital" %}{% set bodyClass = "project-page photo-gallery-page photo-gallery-page--digital" %}
{% else %}{% set bodyClass = "project-page" %}{% endif %}
{% if variantClass %}{% set bodyClass = bodyClass + " " + variantClass %}{% endif %}
{% extends "base.njk" %}
{% block content %}
  {% if modelo == "video-vertical" %}{% include "vertical.njk" %}
  {% elif modelo == "roteiro" %}{% include "script.njk" %}
  {% elif modelo == "galeria-still" or modelo == "fotografia-digital" %}{% include "gallery.njk" %}
  {% else %}{% include "project.njk" %}{% endif %}
{% endblock %}
