<section class="script-hero"><a class="back-link" href="{{ '/index.html#trabalhos' | url }}">← Voltar aos trabalhos</a><div class="script-hero-grid"><div class="script-intro reveal"><p class="eyebrow">{{ eyebrow }}</p><h1>{{ titulo | safe }}</h1><p class="script-logline">{{ logline }}</p>{% if linkExterno %}<a class="project-action" href="{{ linkExterno }}">{{ linkTexto or 'Ler roteiro ↗' }}</a>{% endif %}<dl class="script-facts">{% for item in fatos %}<div><dt>{{ item.rotulo }}</dt><dd>{{ item.valor }}</dd></div>{% endfor %}</dl></div><figure class="script-cover reveal"><img src="{{ capa | url }}" alt="{{ capaAlt }}" /><figcaption>Capa do roteiro</figcaption></figure></div></section>
<section class="script-writing section reveal"><header class="script-section-heading"><p class="eyebrow">Desenvolvimento</p><h2>Sobre a escrita</h2></header><div class="script-text-blocks">{% for bloco in blocosRoteiro %}<article><h3>{{ bloco.titulo }}</h3><p>{{ bloco.texto }}</p></article>{% endfor %}</div></section>
{% if trecho %}<section class="script-excerpt section reveal"><div><p class="eyebrow">Página selecionada</p><h2>Trecho do roteiro</h2></div><div class="screenplay-sample"><p>{{ trecho | nl2br | safe }}</p></div></section>{% endif %}
{% if creditos %}<section class="detail-credits section reveal"><h2>Informações</h2><dl class="credits">{% for item in creditos %}<div><dt>{{ item.rotulo }}</dt><dd>{{ item.valor }}</dd></div>{% endfor %}</dl></section>{% endif %}
