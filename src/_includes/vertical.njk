<section class="vertical-project"><a class="back-link" href="{{ '/index.html#trabalhos' | url }}">← Voltar aos trabalhos</a><div class="vertical-project-layout"><div class="vertical-project-copy reveal"><p class="eyebrow">{{ eyebrow }}</p><h1>{{ titulo }}</h1><p class="vertical-summary">{{ resumo }}</p><dl class="vertical-facts">{% for item in fatos %}<div><dt>{{ item.rotulo }}</dt><dd>{{ item.valor }}</dd></div>{% endfor %}</dl><div class="vertical-about"><h2>Sobre</h2><div class="vertical-about-copy">{{ content | sanitizeContent | safe }}{% if linkExterno %}<a class="project-action" href="{{ linkExterno | safeExternalUrl }}" target="_blank" rel="noopener noreferrer">{{ linkTexto or 'Ver vídeo ↗' }}</a>{% endif %}</div></div></div><figure class="vertical-media reveal">{% image capa, capaAlt, "(max-width: 760px) 90vw, 40vw", "eager", "high" %}</figure></div></section>
