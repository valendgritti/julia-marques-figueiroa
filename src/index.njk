<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ site.seoDescription }}" />
  <base href="{{ '/' | url }}" />
  <title>Julia Marques Figueirôa — Cinema & Audiovisual</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Italiana&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="styles.css" />
  <script src="script.js" defer></script>
</head>

<body>
  <div class="grain" aria-hidden="true"></div>

  <header class="site-header">
    <a class="logo" href="#inicio" aria-label="Voltar ao início">JF<span>®</span></a>

    <button class="menu-button" type="button" aria-expanded="false" aria-controls="menu">
      <span></span><span></span>
      <span class="sr-only">Abrir menu</span>
    </button>

    <nav id="menu" class="menu" aria-label="Navegação principal">
      <a href="#trabalhos">Trabalhos</a>
      <a href="#sobre">Sobre</a>
      <a href="#contato">Contato</a>
    </nav>
  </header>

  <main>
    <section id="inicio" class="hero">
      <div class="hero-copy reveal">
        <p class="eyebrow">{{ site.heroEyebrow }}</p>
        <h1>{{ site.heroTitle | stylizedTitle | safe }}</h1>
        <p class="hero-intro">{{ site.heroIntro }}</p>
      </div>

      <div class="hero-visual reveal" data-hero-carousel aria-label="Imagens de destaque" tabindex="0">
        <div class="hero-slides">
          {% for slide in site.heroSlides %}<figure class="hero-slide{% if loop.first %} active{% endif %}" aria-hidden="{% if loop.first %}false{% else %}true{% endif %}"><img src="{{ slide.imagem | url }}" alt="{{ slide.descricao }}" /></figure>{% endfor %}
        </div>
        <p class="frame-number" aria-live="polite">FRAME <span data-frame-current>01</span> / <span data-frame-total>{% if site.heroSlides | length < 10 %}0{% endif %}{{ site.heroSlides | length }}</span></p>
        {% if site.heroSlides | length > 1 %}<div class="hero-controls"><button type="button" data-hero-previous aria-label="Imagem anterior">←</button><button type="button" data-hero-next aria-label="Próxima imagem">→</button></div>{% endif %}
        <div class="light-leak"></div>
      </div>

      <a class="scroll-hint" href="#trabalhos">Ver trabalhos <span>↓</span></a>
    </section>

    <section id="trabalhos" class="works section">
      <header class="section-heading reveal">
        <p class="eyebrow"></p>
        <h2>{{ site.worksTitle }}</h2>
        <p>{{ site.worksIntro }}</p>
      </header>

      <div class="project-filters reveal" aria-label="Filtrar trabalhos por categoria">
        <button class="filter-button active" type="button" data-filter="todos" aria-pressed="true">
          Todos
        </button>
        <button class="filter-button" type="button" data-filter="producao" aria-pressed="false">
          Produção
        </button>
        <button class="filter-button" type="button" data-filter="fotografia" aria-pressed="false">
          Fotografia
        </button>
        <button class="filter-button" type="button" data-filter="edicao" aria-pressed="false">
          Edição
        </button>
        <button class="filter-button" type="button" data-filter="diversos" aria-pressed="false">
          Diversos
        </button>
      </div>

      <div class="subcategory-filters" data-category="fotografia" aria-label="Filtrar trabalhos de fotografia" hidden>
        <button class="subcategory-button active" type="button" data-subfilter="todos" aria-pressed="true">
          Todos
        </button>
        <button class="subcategory-button" type="button" data-subfilter="direcao-foto" aria-pressed="false">
          Direção de foto
        </button>
        <button class="subcategory-button" type="button" data-subfilter="foto-still" aria-pressed="false">
          Foto still
        </button>
        <button class="subcategory-button" type="button" data-subfilter="fotografia-digital" aria-pressed="false">
          Fotografia digital
        </button>
      </div>

      <div class="subcategory-filters" data-category="diversos" aria-label="Filtrar trabalhos diversos" hidden>
        <button class="subcategory-button active" type="button" data-subfilter="todos" aria-pressed="true">
          Todos
        </button>
        <button class="subcategory-button" type="button" data-subfilter="direcao" aria-pressed="false">
          Direção
        </button>
        <button class="subcategory-button" type="button" data-subfilter="direcao-som" aria-pressed="false">
          Direção de som
        </button>
        <button class="subcategory-button" type="button" data-subfilter="roteiros" aria-pressed="false">
          Roteiros
        </button>
      </div>

      <p class="filter-result reveal" aria-live="polite">Exibindo todos os trabalhos</p>

      <div class="project-list">
        {% for item in collections.projeto | sort(attribute="data.ordem") %}
        <article class="project reveal" data-category="{{ item.data.categoria }}" data-order="{{ item.data.ordem }}"{% if item.data.subcategoria %} data-subcategory="{{ item.data.subcategoria }}"{% endif %}>
          <div class="project-image project-image--{{ item.data.categoria }}"><span>01</span><img src="{{ item.data.capa | url }}" alt="{{ item.data.capaAlt }}" /></div>
          <div class="project-info"><p class="project-meta">{{ item.data.eyebrow }}</p><h3>{{ item.data.titulo }}</h3><p>{{ item.data.resumo }}</p><a href="{{ item.url | url }}" aria-label="Conhecer o projeto {{ item.data.titulo }}">Conhecer projeto ↗</a></div>
        </article>
        {% endfor %}
      </div>
    </section>

    <section id="sobre" class="about section">
      <p class="about-index reveal">02 — Sobre</p>
      <div class="about-content reveal">
        <h2>{{ site.aboutTitle | stylizedTitle | safe }}</h2>
        <div class="about-text">
          <p>{{ site.aboutText | nl2br | safe }}</p>
        </div>
      </div>
    </section>

    <section id="contato" class="contact section reveal">
      <p class="eyebrow">{{ site.contactEyebrow }}</p>
      <h2>{{ site.contactTitle | stylizedTitle | safe }}</h2>
      <div class="contact-list">
        <a class="contact-link">
          <span>E-mail</span>
          <strong>{{ site.email }}</strong>
        </a>
        <a class="contact-link" href="{{ site.whatsappUrl }}" target="_blank" rel="noopener noreferrer">
          <span>WhatsApp</span>
          <strong>{{ site.whatsappLabel }}</strong>
          <span aria-hidden="true">↗</span>
        </a>
        <a class="contact-link" href="{{ site.linkedinUrl }}" target="_blank"
          rel="noopener noreferrer">
          <span>LinkedIn</span>
          <strong>{{ site.linkedinLabel }}</strong>
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </section>
  </main>

  <footer>
    <p>© <span id="current-year"></span> Julia Marques Figueirôa</p>
    <p>Feito com intenção, imagem e movimento.</p>
  </footer>
</body>

</html>
